<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8" /><title>Two-factor authentication</title>
<style>body,table,td{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}table{border-collapse:collapse}@media(max-width:600px){.email-container{width:100%!important}.email-content{padding:32px 20px!important}}@media(prefers-color-scheme:dark){.email-body{background-color:#09090b!important}.email-container{background-color:#18181b!important}.email-heading,.email-brand{color:#fff!important}.email-text{color:#a1a1aa!important}.email-text-muted{color:#71717a!important}.email-border{border-color:#27272a!important}.email-code-box{background-color:#27272a!important}.email-code-text{color:#fff!important}}</style></head>
<body style="margin:0;padding:0;background-color:#fafafa" class="email-body"><table role="presentation" width="100%" style="background-color:#fafafa" class="email-body"><tr><td align="center" style="padding:24px 16px"><table role="presentation" width="560" class="email-container" style="background-color:#fff;border-radius:8px;max-width:560px"><tr><td class="email-content" style="padding:48px 32px"><table role="presentation" width="100%"><tr><td style="padding-bottom:16px"><span style="font-size:18px;font-weight:700;color:#09090b" class="email-brand">Better Email</span></td></tr><tr><td style="border-top:1px solid #e4e4e7;padding-bottom:24px" class="email-border"></td></tr></table><h1 style="font-size:24px;font-weight:600;color:#09090b;margin:0 0 8px 0" class="email-heading">Two-factor authentication</h1><p style="font-size:14px;line-height:24px;color:#3f3f46;margin:0 0 12px 0" class="email-text">Hi {{user.name}},</p><p style="font-size:14px;line-height:24px;color:#3f3f46;margin:0 0 12px 0" class="email-text">Enter the code below to complete your sign-in. This code is required as part of your two-factor authentication.</p><table role="presentation" width="100%" style="margin:24px 0"><tr><td align="center"><table role="presentation" style="background-color:#f4f4f5;border-radius:8px" class="email-code-box"><tr><td style="padding:20px 32px;text-align:center"><span style="font-size:32px;font-weight:700;letter-spacing:6px;color:#09090b;font-family:'SF Mono',monospace" class="email-code-text">{{otp}}</span></td></tr></table></td></tr></table><p style="font-size:13px;color:#71717a;margin:0" class="email-text-muted">This code expires in 5 minutes. Do not share it with anyone.</p><table role="presentation" width="100%" style="margin-top:32px"><tr><td style="border-top:1px solid #e4e4e7;padding-top:16px" class="email-border"></td></tr><tr><td style="font-size:12px;color:#71717a;padding-bottom:8px" class="email-text-muted">If you did not attempt to sign in, someone may have your password. Please change it immediately.</td></tr><tr><td style="font-size:12px;color:#71717a" class="email-text-muted">Sent by Better Email</td></tr></table></td></tr></table></td></tr></table></body></html>
