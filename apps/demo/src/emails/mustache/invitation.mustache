<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8" /><title>Organization invitation</title>
<style>body,table,td{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}table{border-collapse:collapse}@media(max-width:600px){.email-container{width:100%!important}.email-content{padding:32px 20px!important}}@media(prefers-color-scheme:dark){.email-body{background-color:#09090b!important}.email-container{background-color:#18181b!important}.email-heading,.email-brand{color:#fff!important}.email-text{color:#a1a1aa!important}.email-text-muted{color:#71717a!important}.email-border{border-color:#27272a!important}.email-details-card{background-color:#27272a!important}.email-detail-label{color:#71717a!important}.email-detail-value{color:#e4e4e7!important}}</style></head>
<body style="margin:0;padding:0;background-color:#fafafa" class="email-body"><table role="presentation" width="100%" style="background-color:#fafafa" class="email-body"><tr><td align="center" style="padding:24px 16px"><table role="presentation" width="560" class="email-container" style="background-color:#fff;border-radius:8px;max-width:560px"><tr><td class="email-content" style="padding:48px 32px"><table role="presentation" width="100%"><tr><td style="padding-bottom:16px"><span style="font-size:18px;font-weight:700;color:#09090b" class="email-brand">Better Email</span></td></tr><tr><td style="border-top:1px solid #e4e4e7;padding-bottom:24px" class="email-border"></td></tr></table><h1 style="font-size:24px;font-weight:600;color:#09090b;margin:0 0 8px 0" class="email-heading">You have been invited</h1><p style="font-size:14px;line-height:24px;color:#3f3f46;margin:0 0 12px 0" class="email-text"><strong>{{inviter.user.name}}</strong> has invited you to join <strong>{{organization.name}}</strong>.</p><table role="presentation" width="100%" style="margin:24px 0;background-color:#fafafa;border-radius:8px" class="email-details-card"><tr><td style="padding:20px 24px"><table role="presentation" width="100%"><tr><td style="font-size:12px;font-weight:600;color:#71717a;text-transform:uppercase;padding:6px 16px 6px 0" class="email-detail-label">Organization</td><td style="font-size:14px;color:#09090b;font-weight:500;padding:6px 0" class="email-detail-value">{{organization.name}}</td></tr><tr><td style="font-size:12px;font-weight:600;color:#71717a;text-transform:uppercase;padding:6px 16px 6px 0" class="email-detail-label">Role</td><td style="font-size:14px;color:#09090b;font-weight:500;padding:6px 0" class="email-detail-value"><span style="display:inline-block;background-color:#18181b;color:#fff;font-size:12px;font-weight:600;padding:2px 10px;border-radius:12px;text-transform:capitalize">{{role}}</span></td></tr><tr><td style="font-size:12px;font-weight:600;color:#71717a;text-transform:uppercase;padding:6px 16px 6px 0" class="email-detail-label">Invited by</td><td style="font-size:14px;color:#09090b;font-weight:500;padding:6px 0" class="email-detail-value">{{inviter.user.name}}</td></tr></table></td></tr></table><p style="font-size:14px;color:#3f3f46;margin:0" class="email-text">Sign in to your account to accept this invitation.</p><table role="presentation" width="100%" style="margin-top:32px"><tr><td style="border-top:1px solid #e4e4e7;padding-top:16px" class="email-border"></td></tr><tr><td style="font-size:12px;color:#71717a" class="email-text-muted">Sent by Better Email</td></tr></table></td></tr></table></td></tr></table></body></html>
