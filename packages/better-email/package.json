{
  "name": "@nuntly/better-email",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "author": "Nuntly",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuntly/better-email.git",
    "directory": "packages/better-email"
  },
  "homepage": "https://github.com/nuntly/better-email#readme",
  "bugs": {
    "url": "https://github.com/nuntly/better-email/issues"
  },
  "keywords": [
    "auth",
    "email",
    "better-auth",
    "nuntly",
    "react-email",
    "react-mjml",
    "mustache"
  ],
  "description": "Better Auth emails made simple with Better Email",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "unbuild",
    "dev": "unbuild --watch",
    "test": "vitest",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "cp ../../README.md . && cp ../../LICENSE .",
    "postpack": "rm -f README.md LICENSE"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "better-auth": ">=1.3.27"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "rimraf": "~6.1.2",
    "unbuild": "3.6.1",
    "vitest": "^2.0.0"
  }
}
